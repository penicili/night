---
interface Tier {
  label: string;
  price: string;
}

interface Item {
  id: string;
  name: string;
  description: string;
  coming_soon: boolean;
  color: string;
  tiers: Tier[];
}

interface Props {
  item: Item;
}

const { item } = Astro.props;

// Full class strings must be literal here so Tailwind includes them at build time
const themes: Record<string, { hover: string; badgeBg: string; badgeText: string; badgeBorder: string; priceActive: string; priceMuted: string }> = {
  red:    { hover: 'hover:border-red-500/50',    badgeBg: 'bg-red-600/30',    badgeText: 'text-red-400',    badgeBorder: 'border-red-500/30',    priceActive: 'text-red-400',    priceMuted: 'text-red-400/40'    },
  purple: { hover: 'hover:border-purple-500/50', badgeBg: 'bg-purple-600/30', badgeText: 'text-purple-400', badgeBorder: 'border-purple-500/30', priceActive: 'text-purple-400', priceMuted: 'text-purple-400/40' },
  green:  { hover: 'hover:border-green-500/50',  badgeBg: 'bg-green-600/30',  badgeText: 'text-green-400',  badgeBorder: 'border-green-500/30',  priceActive: 'text-green-400',  priceMuted: 'text-green-400/40'  },
  cyan:   { hover: 'hover:border-cyan-500/50',   badgeBg: 'bg-cyan-600/30',   badgeText: 'text-cyan-400',   badgeBorder: 'border-cyan-500/30',   priceActive: 'text-cyan-400',   priceMuted: 'text-cyan-400/40'   },
  orange: { hover: 'hover:border-orange-500/50', badgeBg: 'bg-orange-600/30', badgeText: 'text-orange-400', badgeBorder: 'border-orange-500/30', priceActive: 'text-orange-400', priceMuted: 'text-orange-400/40' },
};

const t = themes[item.color] ?? themes.green;
const priceClass = item.coming_soon ? t.priceMuted : t.priceActive;
const labelClass = item.coming_soon ? 'text-slate-500' : 'text-slate-300';
const titleClass = item.coming_soon ? 'text-white/50' : 'text-white';
const descClass  = item.coming_soon ? 'text-slate-600' : 'text-slate-400';
---

<div class={`bg-cardbg border rounded-2xl p-6 relative overflow-hidden transition-colors ${
  item.coming_soon
    ? 'border-white/5 opacity-60'
    : `border-white/10 ${t.hover}`
}`}>
  {item.coming_soon && (
    <span class={`absolute top-3 right-3 px-2 py-1 ${t.badgeBg} ${t.badgeText} border ${t.badgeBorder} rounded text-[10px] font-bold uppercase animate-pulse`}>Coming Soon</span>
  )}
  <h3 class={`text-xl font-bold mb-2 ${titleClass}`}>{item.name}</h3>
  <p class={`text-sm mb-4 ${descClass}`}>{item.description}</p>
  <div class="flex flex-col gap-2">
    {item.tiers.map(tier => (
      <div class="flex justify-between items-center bg-white/5 px-4 py-2 rounded-lg">
        <span class={`font-bold ${labelClass}`}>{tier.label}</span>
        <span class={`font-bold ${priceClass}`}>{tier.price}</span>
      </div>
    ))}
  </div>
</div>
