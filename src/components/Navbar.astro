---
interface Props {
  page: 'home' | 'webstore';
}
const { page } = Astro.props;
const isHome = page === 'home';
const isStore = page === 'webstore';
---

<nav id="navbar" class="fixed w-full z-50 transition-all duration-300 bg-transparent py-5">
  <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">

    <!-- Logo -->
    {isHome ? (
      <div class="flex items-center gap-2 cursor-pointer" onclick="window.scrollTo(0,0)">
        <img src="/favicon.jpeg" alt="Logo Night Network" class="w-10 h-10 rounded-lg shadow-lg shadow-purple-500/20 object-cover" />
        <span class="font-bold text-xl tracking-wider text-white hidden sm:block">
          NIGHT <span class="text-purple-500">NETWORK</span>
        </span>
      </div>
    ) : (
      <a href="/" class="flex items-center gap-2 cursor-pointer">
        <img src="/favicon.jpeg" alt="Logo Night Network" class="w-10 h-10 rounded-lg shadow-lg shadow-purple-500/20 object-cover" />
        <span class="font-bold text-xl tracking-wider text-white hidden sm:block">
          NIGHT <span class="text-purple-500">NETWORK</span>
        </span>
      </a>
    )}

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-6 lg:gap-8 font-medium text-sm lg:text-base">
      {isHome && (
        <>
          <a href="#home" class="text-white hover:text-purple-400 transition-colors">Beranda</a>
          <a href="#modes" class="hover:text-purple-400 transition-colors">Mode Game</a>
          <a href="#guide" class="hover:text-purple-400 transition-colors">Cara Bermain</a>
          <a href="/started" class="hover:text-purple-400 transition-colors">Commands</a>
          <a href="#economy" class="hover:text-purple-400 transition-colors">Ekonomi</a>
          <a href="#faq" class="hover:text-purple-400 transition-colors">FAQ</a>
          <a href="/webstore" class="hover:text-purple-400 transition-colors font-bold text-purple-400">Store</a>
        </>
      )}
      {isStore && (
        <>
          <a href="/" class="hover:text-purple-400 transition-colors">Beranda</a>
          <a href="/#modes" class="hover:text-purple-400 transition-colors">Mode Game</a>
          <a href="/#guide" class="hover:text-purple-400 transition-colors">Cara Bermain</a>
          <a href="/started" class="hover:text-purple-400 transition-colors">Commands</a>
          <a href="/#economy" class="hover:text-purple-400 transition-colors">Ekonomi</a>
          <a href="/#faq" class="hover:text-purple-400 transition-colors">FAQ</a>
          <a href="/webstore" class="text-white font-bold border-b-2 border-purple-500 pb-1">Store</a>
        </>
      )}
      <a href="https://discord.gg/x9TpXCgP7S" target="_blank" rel="noopener noreferrer"
         class="bg-purple-600 hover:bg-purple-500 text-white px-5 py-2 rounded-full font-semibold transition-all shadow-[0_0_15px_rgba(147,51,234,0.3)] hover:shadow-[0_0_25px_rgba(147,51,234,0.5)]">
        Discord
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button id="mobile-menu-btn" class="md:hidden text-white focus:outline-none">
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#0d0d1a] border-b border-white/10 flex-col p-4 gap-4">
    {isHome && (
      <>
        <a href="#home"    class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Beranda</a>
        <a href="#modes"   class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Mode Game</a>
        <a href="#guide"   class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Cara Bermain</a>
        <a href="/started" class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Commands</a>
        <a href="#economy" class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Ekonomi</a>
        <a href="#faq"     class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">FAQ</a>
        <a href="/webstore" class="mobile-link text-purple-400 font-bold p-2 hover:bg-white/5 rounded-lg">Store</a>
      </>
    )}
    {isStore && (
      <>
        <a href="/"         class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Beranda</a>
        <a href="/#modes"   class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Mode Game</a>
        <a href="/#guide"   class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Cara Bermain</a>
        <a href="/started"  class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Commands</a>
        <a href="/#economy" class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">Ekonomi</a>
        <a href="/#faq"     class="mobile-link text-white font-medium p-2 hover:bg-white/5 rounded-lg">FAQ</a>
        <a href="/webstore"  class="mobile-link text-white font-bold p-2 bg-white/5 rounded-lg border-l-4 border-purple-500">Store</a>
      </>
    )}
    <a href="https://discord.gg/x9TpXCgP7S" target="_blank" rel="noopener noreferrer"
       class="bg-purple-600 text-white p-3 rounded-lg font-bold text-center mt-2">
      Join Discord
    </a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-[#0a0a14]/90', 'backdrop-blur-md', 'border-b', 'border-white/10', 'py-3');
      navbar.classList.remove('bg-transparent', 'py-5');
    } else {
      navbar.classList.remove('bg-[#0a0a14]/90', 'backdrop-blur-md', 'border-b', 'border-white/10', 'py-3');
      navbar.classList.add('bg-transparent', 'py-5');
    }
  });

  const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu    = document.getElementById('mobile-menu')!;
  const iconMenu      = document.getElementById('icon-menu')!;
  const iconClose     = document.getElementById('icon-close')!;

  function toggleMenu() {
    mobileMenu.classList.toggle('hidden');
    mobileMenu.classList.toggle('flex');
    iconMenu.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  }

  mobileMenuBtn.addEventListener('click', toggleMenu);
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', toggleMenu);
  });
</script>
