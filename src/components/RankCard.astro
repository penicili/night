---
interface Rank {
  id: string;
  tier: number;
  name: string;
  price: string;
  theme: string;
  isFree: boolean;
  isHighest: boolean;
  benefits: string[];
  commands: string[];
}

interface Props {
  rank: Rank;
  waNumber: string;
}

const { rank, waNumber } = Astro.props;

const waMsg  = `Halo Night Network, saya ingin membeli Rank *${rank.name}* seharga *${rank.price}*. Mohon konfirmasi pembelian. Terima kasih!`;
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMsg)}`;

// Full class strings must be literal here so Tailwind includes them at build time
const themes: Record<string, { accent: string; check: string; hover: string; mobileBtnClasses: string }> = {
  slate:   { accent: 'text-slate-400',   check: 'text-slate-500',   hover: 'hover:border-slate-500/50',   mobileBtnClasses: 'text-slate-400 bg-slate-500/10 border border-slate-500/30 hover:bg-slate-500/20'   },
  blue:    { accent: 'text-blue-400',    check: 'text-blue-500',    hover: 'hover:border-blue-400/50',    mobileBtnClasses: 'text-blue-400 bg-blue-500/10 border border-blue-500/30 hover:bg-blue-500/20'       },
  violet:  { accent: 'text-violet-400',  check: 'text-violet-500',  hover: 'hover:border-violet-400/50',  mobileBtnClasses: 'text-violet-400 bg-violet-500/10 border border-violet-500/30 hover:bg-violet-500/20' },
  purple:  { accent: 'text-purple-400',  check: 'text-purple-500',  hover: 'hover:border-purple-400/50',  mobileBtnClasses: 'text-purple-400 bg-purple-500/10 border border-purple-500/30 hover:bg-purple-500/20' },
  fuchsia: { accent: 'text-fuchsia-400', check: 'text-fuchsia-500', hover: 'hover:border-fuchsia-400/50', mobileBtnClasses: 'text-fuchsia-400 bg-fuchsia-500/10 border border-fuchsia-500/30 hover:bg-fuchsia-500/20' },
  amber:   { accent: 'text-amber-400',   check: 'text-amber-500',   hover: 'hover:border-amber-400/50',   mobileBtnClasses: 'text-amber-400 bg-amber-500/10 border border-amber-500/30 hover:bg-amber-500/20'   },
};

const t = themes[rank.theme] ?? themes.slate;

const priceClass = rank.isFree ? 'text-slate-300' : rank.isHighest ? 'text-white' : 'text-green-400';
---

{rank.isHighest ? (

  <!-- CELESTIAL — highest tier special card -->
  <div class="bg-[#0d0a1e] border-2 border-purple-500 rounded-3xl p-8 flex flex-col hover:-translate-y-2 transition-all duration-300 relative overflow-hidden shadow-[0_0_25px_rgba(168,85,247,0.3)] rank-card">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-600/20 to-blue-600/10 pointer-events-none"></div>

    <div class="inline-flex max-w-max bg-gradient-to-r from-purple-500 to-blue-500 text-white text-xs font-bold tracking-widest uppercase mb-3 px-3 py-1 rounded-full relative z-10 shadow-lg shadow-purple-500/50">✨ Highest Tier</div>
    <h3 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-300 to-blue-300 mb-2 relative z-10 rank-title">{rank.name}</h3>
    <div class={`text-2xl font-bold mb-6 relative z-10 rank-price ${priceClass}`}>{rank.price}</div>

    <div class="hidden md:block space-y-4 mb-8 flex-1 text-sm text-slate-200 rank-details relative z-10">
      <div class="font-bold text-white border-b border-purple-500/30 pb-2">Rank Benefits:</div>
      <ul class="space-y-2">
        {rank.benefits.map(b => {
          const star = b.startsWith('★ ');
          return (
            <li class="flex items-start gap-2">
              <span class="text-purple-400">{star ? '★' : '✓'}</span>
              {star ? b.slice(2) : b}
            </li>
          );
        })}
      </ul>
      <div class="font-bold text-white border-b border-purple-500/30 pb-2 pt-2">Fitur / Command:</div>
      <ul class="space-y-2 font-medium text-xs">
        {rank.commands.map(cmd => (
          <li class="flex items-start gap-2"><span class="text-purple-400">»</span> {cmd}</li>
        ))}
      </ul>
    </div>

    <button onclick="openModal(this)" class="md:hidden w-full py-3 mb-3 rounded-xl font-bold text-purple-300 bg-purple-600/30 border border-purple-500/50 hover:bg-purple-600/50 transition-colors relative z-10 shadow-lg shadow-purple-500/20">Lihat Detail</button>
    <a href={waHref} target="_blank" rel="noopener noreferrer" class="text-center w-full py-3 rounded-xl font-bold text-white bg-gradient-to-r from-purple-600 to-blue-600 hover:from-green-600 hover:to-green-500 shadow-lg shadow-purple-500/40 transition-all relative z-10">Beli via WhatsApp</a>
  </div>

) : (

  <!-- Normal rank card -->
  <div class={`bg-cardbg border border-white/10 rounded-3xl p-8 flex flex-col hover:-translate-y-2 ${t.hover} transition-all duration-300 rank-card`}>
    <div class={`${t.accent} text-sm font-bold tracking-widest uppercase mb-2`}>Rank {rank.tier}</div>
    <h3 class="text-3xl font-black text-white mb-2 rank-title">{rank.name}</h3>
    <div class={`text-2xl font-bold mb-6 rank-price ${priceClass}`}>{rank.price}</div>

    <div class="hidden md:block space-y-4 mb-8 flex-1 text-sm text-slate-300 rank-details relative z-10">
      <div class="font-bold text-white border-b border-white/10 pb-2">Rank Benefits:</div>
      <ul class="space-y-2">
        {rank.benefits.map(b => (
          <li class="flex items-start gap-2"><span class={t.check}>✓</span> {b}</li>
        ))}
      </ul>
      <div class="font-bold text-white border-b border-white/10 pb-2 pt-2">Fitur / Command:</div>
      <ul class="space-y-2 text-xs">
        {rank.commands.map(cmd => (
          <li class="flex items-start gap-2"><span class={t.accent}>»</span> {cmd}</li>
        ))}
      </ul>
    </div>

    <button onclick="openModal(this)" class={`md:hidden w-full py-3 mb-3 rounded-xl font-bold ${t.mobileBtnClasses} transition-colors relative z-10`}>Lihat Detail</button>

    {rank.isFree ? (
      <div class="text-center w-full py-3 rounded-xl font-bold text-slate-400 bg-white/5 border border-white/10 relative z-10">Otomatis Didapat</div>
    ) : (
      <a href={waHref} target="_blank" rel="noopener noreferrer" class="text-center w-full py-3 rounded-xl font-bold text-white bg-white/5 border border-white/10 hover:bg-green-600 hover:border-green-600 transition-colors relative z-10">Beli via WhatsApp</a>
    )}
  </div>

)}
