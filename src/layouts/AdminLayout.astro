---
import '../styles/global.css';

interface Props {
  title: string;
  page: string;
}

const { title, page } = Astro.props;

const navItems = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    href: '/admin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
  },
  {
    id: 'ranks',
    label: 'Ranks',
    href: '/admin/ranks',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    id: 'items',
    label: 'Items',
    href: '/admin/items',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
  },
  {
    id: 'guide',
    label: 'Guide',
    href: '/admin/guide',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`,
  },
];
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.jpeg" />
    <title>{title} — Admin | Night Network</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-darkerbg text-slate-200 antialiased min-h-screen flex selection:bg-purple-600 selection:text-white">

    <!-- Sidebar -->
    <aside class="fixed inset-y-0 left-0 w-60 bg-darkbg border-r border-white/[0.06] flex flex-col z-50">

      <!-- Brand -->
      <div class="px-5 py-4 border-b border-white/[0.06]">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center text-white font-black text-sm shadow-lg shadow-purple-600/25 group-hover:bg-purple-500 transition-colors">N</div>
          <div class="min-w-0">
            <div class="text-sm font-bold text-white truncate">Night Network</div>
            <div class="text-[10px] text-purple-400/70 font-medium tracking-widest uppercase">Admin Panel</div>
          </div>
        </a>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-medium transition-all ${
              page === item.id
                ? 'bg-purple-600/15 text-purple-300 border border-purple-500/20'
                : 'text-slate-400 hover:text-slate-200 hover:bg-white/[0.04]'
            }`}
          >
            <span class="shrink-0" set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Bottom -->
      <div class="px-3 pb-4 pt-3 border-t border-white/[0.06] space-y-0.5">
        <a href="/" target="_blank" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-slate-500 hover:text-slate-300 hover:bg-white/[0.04] transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Lihat Site
        </a>
        <a href="/admin/logout" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-red-400/60 hover:text-red-400 hover:bg-red-500/[0.08] transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
          Logout
        </a>
      </div>

    </aside>

    <!-- Main -->
    <div class="flex-1 ml-60 flex flex-col min-h-screen">
      <header class="sticky top-0 z-40 bg-darkerbg/90 backdrop-blur-md border-b border-white/[0.06] px-8 h-14 flex items-center justify-between">
        <h1 class="text-sm font-semibold text-white">{title}</h1>
        <span class="inline-flex items-center gap-1.5 text-xs text-slate-500">
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
          online
        </span>
      </header>
      <main class="flex-1 p-8">
        <slot />
      </main>
    </div>

  </body>
</html>
