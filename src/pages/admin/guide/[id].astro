---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '../../../lib/db';

const { id } = Astro.params;
const [section] = await db`SELECT * FROM guide_sections WHERE id = ${id}`;
if (!section) return Astro.redirect('/admin/guide');

let error = '';

if (Astro.request.method === 'POST') {
  const form       = await Astro.request.formData();
  const title      = (form.get('title') as string).trim();
  const tip        = (form.get('tip') as string).trim() || null;
  const color      = form.get('color') as string;
  const is_premium = form.get('is_premium') === 'on';
  const sort_order = parseInt(form.get('sort_order') as string) || 0;

  try {
    await db`
      UPDATE guide_sections SET title=${title}, tip=${tip}, color=${color},
        is_premium=${is_premium}, sort_order=${sort_order}
      WHERE id = ${id}
    `;
    return Astro.redirect('/admin/guide');
  } catch (e: any) {
    error = e.message ?? 'Terjadi kesalahan.';
  }
}

const commands = await db`SELECT * FROM guide_commands WHERE section_id = ${id} ORDER BY sort_order ASC`;
const colors = ['green', 'purple', 'yellow', 'blue'];
---

<AdminLayout title={`Edit: ${section.title}`} page="guide">
  <div class="max-w-3xl">
    <a href="/admin/guide" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 mb-6 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Kembali
    </a>

    {error && <div class="mb-4 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400">{error}</div>}

    <!-- Edit Section -->
    <form method="POST" class="bg-cardbg border border-white/6 rounded-xl p-6 space-y-4 mb-8">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1.5">Title</label>
          <input name="title" required value={section.title} class="w-full bg-darkerbg border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-purple-500/60 transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1.5">Urutan</label>
          <input name="sort_order" type="number" min="0" value={section.sort_order} class="w-full bg-darkerbg border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-purple-500/60 transition-colors" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1.5">Warna</label>
          <select name="color" class="w-full bg-darkerbg border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-purple-500/60 transition-colors">
            {colors.map(c => <option value={c} selected={c === section.color}>{c}</option>)}
          </select>
        </div>
        <div class="flex items-end pb-2">
          <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer">
            <input name="is_premium" type="checkbox" checked={section.is_premium} class="rounded" />
            Premium
          </label>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-400 mb-1.5">Tip <span class="text-slate-600">(pisah paragraf dengan |)</span></label>
        <textarea name="tip" rows="2" class="w-full bg-darkerbg border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-purple-500/60 transition-colors resize-none">{section.tip ?? ''}</textarea>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="px-5 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium rounded-lg transition-colors">Simpan Section</button>
      </div>
    </form>

    <!-- Commands -->
    <div class="bg-cardbg border border-white/6 rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-white/6">
        <h2 class="text-sm font-semibold text-white">Commands <span class="text-slate-500 font-normal">({commands.length})</span></h2>
        <button id="add-cmd-btn" type="button" class="text-xs text-purple-400 hover:text-purple-300 transition-colors">+ Tambah Command</button>
      </div>

      <table class="w-full text-sm" id="cmd-table">
        <tbody class="divide-y divide-white/4" id="cmd-body">
          {commands.map(cmd => (
            <tr data-id={cmd.id} class="cmd-row">
              <!-- Display mode -->
              <td class="cmd-display px-5 py-3 text-slate-300 font-mono text-xs w-52">{cmd.command}</td>
              <td class="cmd-display px-5 py-3 text-slate-400 text-xs">{cmd.description}</td>
              <td class="cmd-display px-5 py-3 w-32">
                <div class="flex gap-2 justify-end">
                  <button type="button" class="edit-btn text-xs text-slate-400 hover:text-white bg-white/4 hover:bg-white/8 px-2.5 py-1 rounded-lg transition-all">Edit</button>
                  <button type="button" class="del-btn text-xs text-red-400/60 hover:text-red-400 bg-red-500/4 hover:bg-red-500/10 px-2.5 py-1 rounded-lg transition-all">Hapus</button>
                </div>
              </td>
              <!-- Edit mode (hidden) -->
              <td colspan="3" class="cmd-edit hidden px-5 py-3">
                <div class="flex gap-2 items-center">
                  <input class="edit-command bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white font-mono focus:outline-none focus:border-purple-500/60 transition-colors w-52" value={cmd.command} />
                  <input class="edit-description bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-purple-500/60 transition-colors flex-1" value={cmd.description} />
                  <button type="button" class="save-btn text-xs text-green-400 hover:text-green-300 bg-green-500/10 hover:bg-green-500/20 px-2.5 py-1 rounded-lg transition-all shrink-0">Simpan</button>
                  <button type="button" class="cancel-btn text-xs text-slate-500 hover:text-slate-300 px-2 py-1 transition-all shrink-0">Batal</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <!-- Add row (hidden) -->
      <div id="add-row" class="hidden px-5 py-3 border-t border-white/6">
        <div class="flex gap-2 items-center">
          <input id="new-command" placeholder="/command" class="bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white font-mono focus:outline-none focus:border-purple-500/60 transition-colors w-52" />
          <input id="new-description" placeholder="Deskripsi command..." class="bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-purple-500/60 transition-colors flex-1" />
          <button id="save-new-btn" type="button" class="text-xs text-green-400 hover:text-green-300 bg-green-500/10 hover:bg-green-500/20 px-2.5 py-1 rounded-lg transition-all shrink-0">Tambah</button>
          <button id="cancel-new-btn" type="button" class="text-xs text-slate-500 hover:text-slate-300 px-2 py-1 transition-all shrink-0">Batal</button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ sectionId: section.id }}>
  // ── Inline edit ──────────────────────────────────────────
  document.querySelectorAll('.cmd-row').forEach(row => {
    const id       = row.dataset.id;
    const displays = row.querySelectorAll('.cmd-display');
    const edits    = row.querySelectorAll('.cmd-edit');

    row.querySelector('.edit-btn').addEventListener('click', () => {
      displays.forEach(el => el.classList.add('hidden'));
      edits.forEach(el => el.classList.remove('hidden'));
    });

    row.querySelector('.cancel-btn').addEventListener('click', () => {
      displays.forEach(el => el.classList.remove('hidden'));
      edits.forEach(el => el.classList.add('hidden'));
    });

    row.querySelector('.save-btn').addEventListener('click', async () => {
      const command     = row.querySelector('.edit-command').value.trim();
      const description = row.querySelector('.edit-description').value.trim();
      const res = await fetch(`/api/guide/commands/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command, description }),
      });
      if (res.ok) {
        row.querySelector('.cmd-display:nth-child(1)').textContent = command;
        row.querySelector('.cmd-display:nth-child(2)').textContent = description;
        displays.forEach(el => el.classList.remove('hidden'));
        edits.forEach(el => el.classList.add('hidden'));
      } else {
        alert('Gagal menyimpan.');
      }
    });

    row.querySelector('.del-btn').addEventListener('click', async () => {
      if (!confirm('Hapus command ini?')) return;
      const res = await fetch(`/api/guide/commands/${id}`, { method: 'DELETE' });
      if (res.ok) row.remove();
      else alert('Gagal menghapus.');
    });
  });

  // ── Add new command ──────────────────────────────────────
  const addBtn    = document.getElementById('add-cmd-btn');
  const addRow    = document.getElementById('add-row');
  const cancelNew = document.getElementById('cancel-new-btn');
  const saveNew   = document.getElementById('save-new-btn');

  addBtn.addEventListener('click', () => addRow.classList.remove('hidden'));
  cancelNew.addEventListener('click', () => {
    addRow.classList.add('hidden');
    document.getElementById('new-command').value = '';
    document.getElementById('new-description').value = '';
  });

  saveNew.addEventListener('click', async () => {
    const command     = document.getElementById('new-command').value.trim();
    const description = document.getElementById('new-description').value.trim();
    if (!command || !description) return alert('Command dan deskripsi wajib diisi.');

    const res = await fetch(`/api/guide/sections/${sectionId}/commands`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ command, description }),
    });

    if (res.ok) {
      const { id } = await res.json();
      const tbody = document.getElementById('cmd-body');
      const tr = document.createElement('tr');
      tr.dataset.id = id;
      tr.className = 'cmd-row';
      tr.innerHTML = `
        <td class="cmd-display px-5 py-3 text-slate-300 font-mono text-xs w-52">${command}</td>
        <td class="cmd-display px-5 py-3 text-slate-400 text-xs">${description}</td>
        <td class="cmd-display px-5 py-3 w-32">
          <div class="flex gap-2 justify-end">
            <button type="button" class="edit-btn text-xs text-slate-400 hover:text-white bg-white/4 hover:bg-white/8 px-2.5 py-1 rounded-lg transition-all">Edit</button>
            <button type="button" class="del-btn text-xs text-red-400/60 hover:text-red-400 bg-red-500/4 hover:bg-red-500/10 px-2.5 py-1 rounded-lg transition-all">Hapus</button>
          </div>
        </td>
        <td colspan="3" class="cmd-edit hidden px-5 py-3">
          <div class="flex gap-2 items-center">
            <input class="edit-command bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white font-mono focus:outline-none focus:border-purple-500/60 transition-colors w-52" value="${command}" />
            <input class="edit-description bg-darkerbg border border-white/8 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-purple-500/60 transition-colors flex-1" value="${description}" />
            <button type="button" class="save-btn text-xs text-green-400 hover:text-green-300 bg-green-500/10 hover:bg-green-500/20 px-2.5 py-1 rounded-lg transition-all shrink-0">Simpan</button>
            <button type="button" class="cancel-btn text-xs text-slate-500 hover:text-slate-300 px-2 py-1 transition-all shrink-0">Batal</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
      // wire up events for new row
      // re-attach by reloading — simplest approach
      window.location.reload();
    } else {
      alert('Gagal menambah command.');
    }
  });
</script>
