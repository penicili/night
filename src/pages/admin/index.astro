---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../lib/db';

const ranks = await db`SELECT * FROM ranks`;
const items = await db`SELECT * FROM items`;


const totalRanks  = ranks.length;
const totalItems  = items.length;
console.log(items);
const activeItems = items.filter(i => i.coming_soon === false).length;
const comingSoon   = totalItems - activeItems;
---

<AdminLayout title="Dashboard" page="dashboard">

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

    <div class="bg-cardbg border border-white/[0.06] rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[11px] font-medium text-slate-500 uppercase tracking-wider">Total Ranks</span>
        <div class="w-7 h-7 bg-purple-500/15 text-purple-400 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-white">{totalRanks}</div>
    </div>

    <div class="bg-cardbg border border-white/[0.06] rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[11px] font-medium text-slate-500 uppercase tracking-wider">Total Items</span>
        <div class="w-7 h-7 bg-blue-500/15 text-blue-400 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-white">{totalItems}</div>
      <div class="text-xs text-slate-500 mt-1">{activeItems} aktif · {comingSoon} coming soon</div>
    </div>


  </div>

  <h2 class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-3">Manajemen Data</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <a href="/admin/ranks" class="bg-cardbg border border-white/[0.06] hover:border-purple-500/30 rounded-xl p-5 flex items-center justify-between group transition-all">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 bg-purple-500/15 text-purple-400 rounded-xl flex items-center justify-center group-hover:bg-purple-500/25 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <div class="font-semibold text-white text-sm">Kelola Ranks</div>
          <div class="text-xs text-slate-500 mt-0.5">Edit, tambah, atau hapus rank premium</div>
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 group-hover:text-purple-400 transition-colors shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>

    <a href="/admin/items" class="bg-cardbg border border-white/[0.06] hover:border-blue-500/30 rounded-xl p-5 flex items-center justify-between group transition-all">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 bg-blue-500/15 text-blue-400 rounded-xl flex items-center justify-center group-hover:bg-blue-500/25 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        </div>
        <div>
          <div class="font-semibold text-white text-sm">Kelola Items</div>
          <div class="text-xs text-slate-500 mt-0.5">Edit, tambah, atau hapus item in-game</div>
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 group-hover:text-blue-400 transition-colors shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>

  </div>

</AdminLayout>
