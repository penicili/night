---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '../../../lib/db';

const items = await db`SELECT * FROM items ORDER BY name ASC`;


---

<AdminLayout title="Items" page="items">

  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-slate-500">{items.length} item terdaftar</p>
    <a href="/admin/items/new" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      Tambah Item
    </a>
  </div>

  <div class="bg-cardbg border border-white/6 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/6">
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Nama</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Deskripsi</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Warna</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Status</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Tiers</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/4">
        {items.map(item => (
          <tr class="hover:bg-white/2 transition-colors">
            <td class="px-5 py-4 text-white text-sm font-medium">{item.name}</td>
            <td class="px-5 py-4 text-slate-400 text-sm max-w-xs truncate">{item.description}</td>
            <td class="px-5 py-4 text-slate-500 text-sm">{item.color}</td>
            <td class="px-5 py-4">
              {item.coming_soon
                ? <span class="px-2 py-0.5 bg-yellow-500/15 text-yellow-400 border border-yellow-500/20 rounded text-[10px] font-medium">Coming Soon</span>
                : <span class="px-2 py-0.5 bg-green-500/15 text-green-400 border border-green-500/20 rounded text-[10px] font-medium">Aktif</span>
              }
            </td>
            <td class="px-5 py-4 text-slate-500 text-xs">{item.tiers.length} tier</td>
            <td class="px-5 py-4">
              <div class="flex items-center gap-2 justify-end">
                <a href={`/admin/items/${item.id}`} class="px-3 py-1.5 text-xs text-slate-400 hover:text-white bg-white/4 hover:bg-white/8 rounded-lg transition-all">
                  Edit
                </a>
                <button
                  type="button"
                  data-id={item.id}
                  class="delete-btn px-3 py-1.5 text-xs text-red-400/60 hover:text-red-400 bg-red-500/4 hover:bg-red-500/10 rounded-lg transition-all"
                >
                  Hapus
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>


<script>
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      if (!confirm(`Hapus item "${id}"?`)) return;

      const res = await fetch(`/api/items/${id}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('tr')?.remove();
      } else {
        alert('Gagal menghapus item.');
      }
    });
  });
</script>

</AdminLayout>
