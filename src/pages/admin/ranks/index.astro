---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '../../../lib/db';

const ranks = await db`SELECT * FROM ranks ORDER BY tier ASC`;


---

<AdminLayout title="Ranks" page="ranks">

  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-slate-500">{ranks.length} rank terdaftar</p>
    <a href="/admin/ranks/new" class="inline-flex items-center gap-2 px-4 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      Tambah Rank
    </a>
  </div>

  <div class="bg-cardbg border border-white/6 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/6">
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Tier</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Nama</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Harga</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Theme</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Status</th>
          <th class="text-left px-5 py-3 text-[11px] font-medium text-slate-500 uppercase tracking-wider">Benefits</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/4">
        {ranks.map(rank => (
          <tr class="hover:bg-white/2 transition-colors">
            <td class="px-5 py-4 text-slate-400 text-sm">{rank.tier}</td>
            <td class="px-5 py-4 text-white text-sm font-medium">{rank.name}</td>
            <td class="px-5 py-4 text-slate-300 text-sm">{rank.price}</td>
            <td class="px-5 py-4 text-slate-500 text-sm">{rank.theme}</td>
            <td class="px-5 py-4">
              <div class="flex flex-wrap gap-1">
                {rank.is_free && (
                  <span class="px-2 py-0.5 bg-green-500/15 text-green-400 border border-green-500/20 rounded text-[10px] font-medium">Free</span>
                )}
                {rank.is_highest && (
                  <span class="px-2 py-0.5 bg-amber-500/15 text-amber-400 border border-amber-500/20 rounded text-[10px] font-medium">Highest</span>
                )}
                {!rank.is_free && !rank.is_highest && (
                  <span class="text-slate-600 text-[10px]">—</span>
                )}
              </div>
            </td>
            <td class="px-5 py-4 text-slate-500 text-xs">{rank.benefits.length} benefit · {rank.commands.length} cmd</td>
            <td class="px-5 py-4">
              <div class="flex items-center gap-2 justify-end">
                <a href={`/admin/ranks/${rank.id}`} class="px-3 py-1.5 text-xs text-slate-400 hover:text-white bg-white/4 hover:bg-white/8 rounded-lg transition-all">
                  Edit
                </a>
                <button
                  type="button"
                  data-id={rank.id}
                  class="delete-btn px-3 py-1.5 text-xs text-red-400/60 hover:text-red-400 bg-red-500/4 hover:bg-red-500/10 rounded-lg transition-all"
                >
                  Hapus
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>


<script>
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      if (!confirm(`Hapus rank "${id}"?`)) return;

      const res = await fetch(`/api/ranks/${id}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('tr')?.remove();
      } else {
        alert('Gagal menghapus rank.');
      }
    });
  });
</script>

</AdminLayout>
