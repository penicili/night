---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { db } from '../lib/db';

// Query semua sections + commands sekaligus
const rows = await db`
  SELECT
    s.id   AS section_id, s.title, s.tip, s.color, s.is_premium,
    c.id   AS cmd_id, c.command, c.description
  FROM guide_sections s
  LEFT JOIN guide_commands c ON c.section_id = s.id
  ORDER BY s.sort_order ASC, c.sort_order ASC
`;

// Group commands ke dalam section masing-masing
const sectionsMap = new Map<number, {
  id: number; title: string; tip: string | null;
  color: string; is_premium: boolean;
  commands: { id: number; command: string; description: string }[];
}>();

for (const row of rows) {
  if (!sectionsMap.has(row.section_id)) {
    sectionsMap.set(row.section_id, {
      id: row.section_id, title: row.title, tip: row.tip,
      color: row.color, is_premium: row.is_premium, commands: [],
    });
  }
  if (row.cmd_id) {
    sectionsMap.get(row.section_id)!.commands.push({
      id: row.cmd_id, command: row.command, description: row.description,
    });
  }
}
const sections = [...sectionsMap.values()];

// Color map — harus literal supaya Tailwind include class-nya
const colorMap: Record<string, {
  border: string; hover: string; iconBg: string;
  tipBg: string; tipBorder: string; tipText: string;
  badge: string;
}> = {
  green: {
    border:    'border-white/10',
    hover:     'hover:border-green-500/30',
    iconBg:    'bg-green-600/20 text-green-400',
    tipBg:     'bg-green-500/10',
    tipBorder: 'border-green-500/20',
    tipText:   'text-green-300',
    badge:     'bg-green-500/20 text-green-400 border-green-500/30',
  },
  purple: {
    border:    'border-white/10',
    hover:     'hover:border-purple-500/30',
    iconBg:    'bg-purple-600/20 text-purple-400',
    tipBg:     'bg-purple-500/10',
    tipBorder: 'border-purple-500/20',
    tipText:   'text-purple-300',
    badge:     'bg-purple-500/20 text-purple-400 border-purple-500/30',
  },
  yellow: {
    border:    'border-yellow-500/30',
    hover:     'hover:border-yellow-500/60',
    iconBg:    'bg-yellow-600/20 text-yellow-400',
    tipBg:     'bg-yellow-500/10',
    tipBorder: 'border-yellow-500/20',
    tipText:   'text-yellow-300',
    badge:     'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  },
  blue: {
    border:    'border-white/10',
    hover:     'hover:border-blue-500/30',
    iconBg:    'bg-blue-600/20 text-blue-400',
    tipBg:     'bg-blue-500/10',
    tipBorder: 'border-blue-500/20',
    tipText:   'text-blue-300',
    badge:     'bg-blue-500/20 text-blue-400 border-blue-500/30',
  },
};
---

<Layout title="Panduan Command | Night Network" bodyClass="flex flex-col min-h-screen">

  <!-- Simple Navbar -->
  <nav class="w-full z-50 bg-darkbg/90 backdrop-blur-md border-b border-white/10 py-4 sticky top-0">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 cursor-pointer group">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-white transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        <span class="font-semibold text-slate-400 group-hover:text-white transition-colors">Kembali ke Beranda</span>
      </a>
      <div class="font-bold tracking-wider text-white hidden sm:block">
        NIGHT <span class="text-purple-500">NETWORK</span>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="grow pt-12 pb-24 relative">
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-100 bg-purple-600/10 blur-[100px] rounded-full"></div>
      <div class="absolute inset-0 minecraft-grid opacity-30 z-0"></div>
    </div>

    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Panduan <span class="text-purple-500">Command & Sistem</span></h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Kumpulan perintah dasar dan sistem unik yang sering digunakan oleh pemain saat bermain di Night Network. Pahami fungsinya untuk mempermudah petualanganmu!
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {sections.map(section => {
          const c = colorMap[section.color] ?? colorMap.green;
          const tips = section.tip ? section.tip.split('|') : [];
          return (
            <div class={`bg-cardbg border ${section.is_premium ? c.border : 'border-white/10'} ${c.hover} rounded-2xl p-6 md:p-8 transition-colors relative overflow-hidden`}>

              {section.is_premium && (
                <div class="absolute top-3 right-3">
                  <span class={`px-2 py-1 ${c.badge} border rounded text-[10px] font-bold uppercase tracking-wider`}>⭐ Premium</span>
                </div>
              )}

              <div class="flex items-center gap-3 mb-6 border-b border-white/5 pb-4">
                <div class={`${c.iconBg} p-3 rounded-xl`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h2 class="text-2xl font-bold text-white">{section.title}</h2>
              </div>

              {tips.length > 0 && (
                <div class={`${c.tipBg} border ${c.tipBorder} rounded-xl px-4 py-3 mb-5 text-sm ${c.tipText} space-y-2`}>
                  {tips.map(tip => <p set:html={tip} />)}
                </div>
              )}

              <ul class="space-y-4">
                {section.commands.map(cmd => (
                  <li>
                    <div class="font-mono font-bold text-white mb-1"><code>{cmd.command}</code></div>
                    <p class="text-sm text-slate-400">{cmd.description}</p>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-footerbg pt-12 pb-8 border-t border-white/5 mt-auto">
    <div class="container mx-auto px-6 md:px-12 text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2 justify-center md:justify-start">
        <img src="/favicon.jpeg" alt="Logo Night Network" class="w-6 h-6 rounded object-cover" />
        <span class="font-bold text-white">NIGHT NETWORK</span>
      </div>
      <p class="text-slate-500 text-sm">&copy; 2026 Night Network. Hak Cipta Dilindungi.</p>
      <div class="text-slate-500 text-sm">Dibuat dengan <span class="text-red-500">&#9829;</span> untuk komunitas MC.</div>
    </div>
  </footer>

</Layout>

<style>
  code {
    background-color: rgba(147, 51, 234, 0.15);
    color: #d8b4fe;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    border: 1px solid rgba(147, 51, 234, 0.3);
  }
</style>
