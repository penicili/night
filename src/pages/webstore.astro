---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import RankCard from '../components/RankCard.astro';
import ItemCard from '../components/ItemCard.astro';
import ranks from '../data/ranks.json';
import items from '../data/items.json';
import { waNumber, waNumberDev, waGreetOwner, waGreetDev } from '../config/store.ts';

const waOwnerHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waGreetOwner)}`;
const waDevHref   = `https://wa.me/${waNumberDev}?text=${encodeURIComponent(waGreetDev)}`;
---

<Layout title="Web Store | Night Network">
  <Navbar page="webstore" />

  <!-- Header Store Section -->
  <header class="pt-32 pb-16 bg-darkerbg border-b border-white/5 relative overflow-hidden store-bg">
    <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-purple-900/30 border border-purple-500/30 text-purple-400 text-sm font-bold tracking-wider mb-4">
        🛍️ OFFICIAL WEB STORE
      </span>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tight">
        NIGHT NETWORK <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400">SHOP</span>
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-4">
        Kami menawarkan beberapa penjualan Rank & Item. Seluruh dana yang masuk digunakan untuk biaya hosting bulanan.
      </p>
      <div class="flex flex-col items-center justify-center gap-2 text-yellow-400 bg-yellow-500/10 border border-yellow-500/20 px-4 py-3 rounded-xl max-w-xl mx-auto">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          <span class="font-bold text-sm md:text-base">Semua Rank Bersifat PERMANEN!</span>
        </div>
        <span class="text-xs md:text-sm text-yellow-500/80">(Sekali beli, selamanya tidak akan hilang dari akunmu)</span>
      </div>
    </div>
  </header>

  <!-- Rank List Section -->
  <section class="py-20 relative">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-10 w-2 bg-purple-600 rounded-full"></div>
        <h2 class="text-3xl font-bold text-white">Paket <span class="text-purple-400">Rank Premium</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ranks.map(rank => <RankCard rank={rank} waNumber={waNumber} />)}
      </div>
    </div>
  </section>

  <!-- Modal for Rank Details (Mobile) -->
  <div id="rank-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
    <div class="relative bg-cardbg border border-white/10 rounded-2xl w-full max-w-md max-h-[85vh] flex flex-col shadow-2xl overflow-hidden z-10 animate-[pulse_0.1s_ease-out_1]">
      <div class="flex justify-between items-center p-5 border-b border-white/10 bg-darkbg">
        <div>
          <h3 id="modal-title" class="text-2xl font-black text-white tracking-wide">Rank Name</h3>
          <div id="modal-price" class="text-lg font-bold text-green-400">Rp 0</div>
        </div>
        <button onclick="closeModal()" class="text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 p-2 rounded-lg transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div id="modal-body" class="p-6 overflow-y-auto modal-scroll space-y-4 text-sm text-slate-300"></div>
      <div class="p-5 border-t border-white/10 bg-darkbg">
        <a href="#pembayaran" onclick="closeModal()" class="block text-center w-full py-3 rounded-xl font-bold text-white bg-green-600 hover:bg-green-500 shadow-lg shadow-green-500/20 transition-colors">Lanjut Pembayaran</a>
      </div>
    </div>
  </div>

  <!-- Items Price List Section -->
  <section class="py-16 bg-[#0c0c16] border-y border-white/5">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex items-center gap-4 mb-8">
        <div class="h-8 w-2 bg-blue-600 rounded-full"></div>
        <h2 class="text-2xl font-bold text-white">Item <span class="text-blue-400">In-Game</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => <ItemCard item={item} />)}
      </div>
    </div>
  </section>

  <!-- Payment / Contact Section -->
  <section id="pembayaran" class="py-20 bg-darkbg text-center relative scroll-mt-10">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-[300px] bg-green-500/10 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <h2 class="text-3xl font-bold text-white mb-4">Cara Melakukan Pembelian</h2>
      <p class="text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
        Pilih paket Rank atau Item yang ingin Anda beli. Segala bentuk transaksi <strong>HANYA</strong> dilakukan melalui kedua kontak WhatsApp resmi di bawah ini. Harap berhati-hati terhadap penipuan.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-6 max-w-3xl mx-auto">

        <!-- WA Owner -->
        <a href={waOwnerHref} target="_blank" rel="noopener noreferrer"
           class="flex-1 bg-[#121220] hover:bg-[#1a1a2e] border border-white/10 hover:border-green-500/50 p-6 rounded-2xl transition-all duration-300 group flex flex-col items-center">
          <div class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-green-500 group-hover:text-white transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-1">Chat Owner</h3>
          <p class="text-sm text-slate-400 mb-2">Kaitou</p>
          <p class="text-green-400 font-mono font-bold">+60 16-758 6067</p>
        </a>

        <!-- WA Dev -->
        <a href={waDevHref} target="_blank" rel="noopener noreferrer"
           class="flex-1 bg-[#121220] hover:bg-[#1a1a2e] border border-white/10 hover:border-green-500/50 p-6 rounded-2xl transition-all duration-300 group flex flex-col items-center">
          <div class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-green-500 group-hover:text-white transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-1">Chat Dev</h3>
          <p class="text-sm text-slate-400 mb-2">Menki</p>
          <p class="text-green-400 font-mono font-bold">08979771541</p>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Modal logic
  const rankModal  = document.getElementById('rank-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalPrice = document.getElementById('modal-price')!;
  const modalBody  = document.getElementById('modal-body')!;

  function openModal(btnElement: HTMLElement) {
    const card = btnElement.closest('.rank-card')!;
    modalTitle.textContent = card.querySelector('.rank-title')?.textContent ?? '';
    modalPrice.textContent = card.querySelector('.rank-price')?.textContent ?? '';
    modalBody.innerHTML    = card.querySelector('.rank-details')?.innerHTML ?? '';
    rankModal.classList.remove('hidden');
    rankModal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    rankModal.classList.add('hidden');
    rankModal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Make openModal/closeModal available globally for onclick attributes
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
</script>
